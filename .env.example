# Copier en .env et ajuster
ENVIRONMENT=local

# Ligue virtuelle ciblee (English League)
LEAGUE_ID=8035

# Base de donnees (SQLite ; WAL active automatiquement)
DATABASE_URL=sqlite:///bet261.db
# Logs SQL detailles (debug uniquement)
SQL_ECHO=false

# Collecte
POLL_INTERVAL_SECONDS=60
ALL_MARKETS=false
ENABLE_SCHEDULER=true

# Analyse : decalage horaire d'affichage (Madagascar = 3)
TZ_OFFSET=3

# Securite optionnelle : decommenter pour exiger l'entete X-API-Key
# API_KEY=remplace-par-une-longue-chaine-aleatoire
